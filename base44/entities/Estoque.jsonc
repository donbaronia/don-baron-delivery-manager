    },
    "categoria": {
      "type": "string"
    },
    "valor": {
      "type": "number"
    },
    "quantidade": {
      "type": "number",
      "default": 0
    },
    "unidade": {
      "type": "string",
      "default": "un"
    }
  },
  "required": [
